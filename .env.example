# Database (OJ)
MYSQL_ROOT_PASSWORD=hustoj_root
MYSQL_PASSWORD=hustoj

# Backend
SECRET_KEY=change-this-to-a-random-secret-key

# Nextcloud DB
NEXTCLOUD_DB_ROOT_PASSWORD=nextcloud_root
NEXTCLOUD_DB_PASSWORD=nextcloud

# Nextcloud 관리자
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-this-password

# Nextcloud 접속 도메인 또는 IP (공백 구분으로 여러 개 가능)
NEXTCLOUD_TRUSTED_DOMAINS=localhost

# Nextcloud 데이터 저장 경로 (기본: /opt/nextcloud-data, 외장SSD: /mnt/external)
NEXTCLOUD_STORAGE_PATH=/opt/nextcloud-data
